<%
const riskCards = [
  {
    mode: 'Консервативный',
    income: 'Доход: 5-8% в месяц',
    body: 'Возможен долив 50% от депозита',
    note: '(по истории: 2 года без долива)',
    drawdown: 'Просадка: 35%',
    className: '!bg-[#1f1e1b]',
  },
  {
    mode: 'Умеренный',
    income: 'Доход: 8-12% в месяц',
    body: 'Возможен долив 100% от депозита',
    note: '(по истории: 1,5 года без долива)',
    drawdown: 'Просадка: 56%',
    className: '!bg-[#1f1e1b]',
  },
  {
    mode: 'Агрессивный',
    income: 'Доход: 12-20% в месяц',
    body: 'Возможен долив 100-200% от депозита',
    note: '(периодически требует долива)',
    drawdown: 'Просадка: 56%',
    className: '!bg-[#1f1e1b]',
  },
  {
    mode: 'GOLD NEW *',
    income: 'Доход: до 40% в сутки',
    body: 'Риски ограничиваются депозитом',
    note: '<br>',
    drawdown: 'Просадка: 100%',
    className: '!bg-[#3d3a36]',
  },
];
%>

<section id="risks" class="layout-section relative overflow-visible" aria-labelledby="risks-strategy-title" data-section="risks-strategy">
  <img
    src="/images/figma/gold-ellipse.svg"
    alt=""
    aria-hidden="true"
    class="pointer-events-none absolute left-[-216px] top-[589px] z-0 size-[1200px] max-w-none md:hidden"
  >

  <div class="layout-container relative z-10 flex flex-col items-center gap-8 md:gap-11">
    <div class="flex w-full flex-col items-start gap-4">
      <h2 id="risks-strategy-title" class="type-h2 w-full text-white">Какие у&nbsp;меня риски?</h2>
      <p class="type-h4 w-full text-text">У&nbsp;советника есть 4&nbsp;режима:</p>
    </div>

    <div class="grid w-full grid-cols-1 items-stretch gap-4 md:grid-cols-2 lg:h-[283px] lg:grid-cols-4 lg:gap-6">
      <% riskCards.forEach(function (card) { %>
        <%- include('../ui/card', {
          padded: false,
          bordered: false,
          className: ['flex h-full w-full flex-col !rounded-[16px] p-4 text-white md:!rounded-[24px] md:p-6 lg:min-w-0', card.className].join(' '),
          contentClassName: 'h-full gap-6',
          html: `
            <div class="flex w-full flex-col items-start gap-2 font-semibold text-white">
              <p class="w-full text-[14px] leading-[1.2] lg:text-[16px] lg:leading-none">Режим</p>
              <h3 class="w-full text-[18px] leading-[1.16] font-semibold lg:text-[20px]">${card.mode}</h3>
            </div>

            <div class="flex w-full flex-col items-start gap-4 text-white">
              <p class="w-full text-[18px] leading-[1.16] font-semibold lg:text-[20px]">${card.income}</p>
              <div class="flex w-full flex-col items-start gap-2">
                <p class="w-full text-[14px] leading-[1.48] lg:text-[16px]">${card.body}</p>
                <p class="w-full text-[12px] leading-[1.48] lg:text-[14px]">${card.note}</p>
              </div>
            </div>

            <p class="w-full text-[14px] leading-[1.48] text-[#b8b8b8] lg:mt-auto lg:text-[16px]">${card.drawdown}</p>
          `,
        }) %>
      <% }) %>
    </div>

    <%- include('../ui/button', {
      label: 'Подключить бота',
      href: 'https://youtu.be/yNU3TM6PKCk',
      size: 'large',
      className: 'h-12 w-full md:w-auto',
      attributes: { 'aria-label': 'Подключить бота', target: '_blank', rel: 'noopener noreferrer' },
    }) %>
  </div>
</section>
