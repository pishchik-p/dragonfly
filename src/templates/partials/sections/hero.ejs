<section class="relative isolate overflow-hidden pt-[134px] pb-0 md:pt-[170px] md:pb-0" aria-labelledby="hero-title">
  <img
    src="/images/figma/hero-market-bg.png"
    alt=""
    class="pointer-events-none absolute left-1/2 top-[-24px] -z-20 h-[560px] w-[996px] max-w-none -translate-x-1/2 object-cover opacity-25 md:top-[-140px] md:h-[810px] md:w-[1440px]"
    aria-hidden="true"
  >
  <div class="layout-container">
    <div class="flex flex-col gap-8 md:flex-row md:items-start md:gap-0 lg:gap-6">
      <div class="flex min-w-0 flex-1 flex-col gap-8 md:gap-[60px] lg:h-[496px] lg:justify-between">
        <div class="flex flex-col gap-6 text-white md:gap-11">
          <h1 id="hero-title" class="type-h1 max-w-[760px] text-white">
            Софт для&nbsp;автоматизированной торговли
          </h1>
          <p class="type-h3 text-white">Торговые роботы DRAGONFLY</p>
        </div>

        <div class="flex flex-col items-center gap-6 md:w-fit md:pb-11 lg:gap-8 xl:flex-row xl:items-center xl:gap-11 xl:pb-[112px]">
          <div class="flex w-full flex-col gap-4 md:w-auto md:flex-row md:items-center md:gap-6">
            <%- include('../ui/button', {
              label: 'Подключить бота',
              href: 'https://youtu.be/xOcFb_trRMw?si=qsBxsej-1dmHWzk9',
              variant: 'primary',
              size: 'large',
              className: 'w-full md:w-auto',
              attributes: { 'aria-label': 'Подключить торгового бота DRAGONFLY', target: '_blank', rel: 'noopener noreferrer' }
            }) %>
            <%- include('../ui/button', {
              label: 'Узнать подробнее',
              href: '#income',
              variant: 'secondary',
              size: 'large',
              className: 'w-full md:w-auto',
              attributes: { 'aria-label': 'Узнать подробнее о торговом боте DRAGONFLY' }
            }) %>
          </div>

          <a
            href="#risks"
            class="type-button inline-flex items-center justify-center gap-3 text-center text-white underline decoration-white underline-offset-2 transition-colors hover:text-accent-hover hover:decoration-accent-hover focus-visible:rounded-sm md:self-center xl:self-auto xl:shrink-0"
            aria-label="Ознакомиться с рисками торговли"
            aria-controls="risk-modal"
            aria-haspopup="dialog"
            data-risk-modal-open
          >
            <span>Ознакомиться с&nbsp;рисками</span>
            <img src="/icons/figma/arrow-right.svg" alt="" class="h-3 w-3 shrink-0" aria-hidden="true">
          </a>
        </div>
      </div>

      <div class="relative h-[294px] w-full shrink-0 md:h-[372px] md:w-[273px] md:self-end md:pb-11 md:pr-3 lg:h-[496px] lg:w-[414px] lg:self-end lg:pb-11 lg:pr-0" aria-hidden="true">
        <div class="absolute right-4 top-0 h-full w-[247px] overflow-hidden md:left-1/2 md:right-auto md:top-auto md:bottom-11 md:h-[328px] md:w-[242px] md:-translate-x-1/2 md:overflow-visible lg:top-0 lg:bottom-auto lg:h-[496px] lg:w-[366px] lg:overflow-hidden">
          <img
            src="/images/figma/hero-person.png"
            alt=""
            class="absolute left-0 top-0 h-auto w-full max-w-none"
            loading="eager"
            decoding="async"
          >
        </div>

        <div class="pointer-events-none absolute left-0 top-[140px] flex flex-col items-start gap-4 md:left-[-15px] md:top-auto md:bottom-11 md:pr-3 lg:left-[-24px] lg:bottom-11 lg:gap-6 lg:pr-0 xl:bottom-[88px]">
          <%- include('../ui/tag', {
            label: 'Установка и настройка',
            className: 'ml-5 md:ml-[17px] lg:ml-7'
          }) %>
          <%- include('../ui/tag', {
            label: 'Техническая поддержка',
            className: ''
          }) %>
          <%- include('../ui/tag', {
            label: 'Инструкции',
            className: 'ml-10 md:ml-[47px] lg:ml-[72px]'
          }) %>
        </div>
      </div>
    </div>
  </div>
</section>
