<%
const pricingPlans = content.pricingPlans;
const renderFeatureList = function (items, iconSrc, labelledBy) {
%>
  <ul class="flex list-none flex-col gap-2 p-0" aria-labelledby="<%= labelledBy %>">
    <% items.forEach(function (item) { %>
      <li class="flex items-start gap-2 text-[14px] leading-[1.48] text-white lg:text-[16px]">
        <span class="mt-[1px] flex size-5 shrink-0 items-center justify-center text-accent md:size-6" aria-hidden="true">
          <img src="<%= iconSrc %>" alt="" class="size-full max-w-none">
        </span>
        <span class="min-w-0 flex-1"><%= item %></span>
      </li>
    <% }) %>
  </ul>
<%
};
%>

<section id="pricing" class="layout-section" aria-labelledby="pricing-title" data-section="pricing">
  <div class="layout-container flex flex-col gap-8 md:gap-11">
    <h2 id="pricing-title" class="type-h2 w-full text-white">
      Стоимость робота
    </h2>

    <div class="grid w-full grid-cols-1 items-stretch gap-4 md:grid-cols-2 lg:gap-6">
      <% pricingPlans.forEach(function (plan, planIndex) { %>
        <article
          class="flex min-w-0 flex-1 flex-col gap-6 rounded-[16px] bg-[#1f1e1b] px-4 pt-5 pb-4 text-white md:rounded-[24px] md:px-6 md:pt-7 md:pb-6"
          aria-labelledby="pricing-plan-<%= planIndex %>-title"
        >
          <h3 id="pricing-plan-<%= planIndex %>-title" class="text-[24px] font-bold leading-[1.16] text-white lg:text-[32px]">
            <%= plan.title %>
          </h3>

          <div class="flex flex-col gap-6">
            <section class="flex flex-col gap-4" aria-labelledby="pricing-plan-<%= planIndex %>-included-title">
              <h4 id="pricing-plan-<%= planIndex %>-included-title" class="text-[18px] font-semibold leading-[1.16] text-white lg:text-[20px]">
                Что&nbsp;включает:
              </h4>
              <% renderFeatureList(plan.included, '/icons/pricing-plus.svg', `pricing-plan-${planIndex}-included-title`); %>
            </section>

            <section class="flex flex-col gap-4 border-t border-[#29261F] pt-6" aria-labelledby="pricing-plan-<%= planIndex %>-benefits-title">
              <h4 id="pricing-plan-<%= planIndex %>-benefits-title" class="text-[18px] font-semibold leading-[1.16] text-white lg:text-[20px]">
                Преимущества:
              </h4>
              <% renderFeatureList(plan.benefits, '/icons/pricing-check.svg', `pricing-plan-${planIndex}-benefits-title`); %>
            </section>
          </div>

          <p class="text-[12px] leading-[1.48] text-text lg:text-[14px]">
            * одновременно может быть запущен один алгоритм на&nbsp;выбор
          </p>

          <div class="mt-auto flex flex-row items-center justify-between gap-4 border-t border-[#29261F] pt-6">
            <p class="text-[20px] font-semibold leading-[1.16] text-white lg:text-[28px]"><%= plan.price %></p>
            <%- include('../ui/button', {
              label: 'Подключить бота',
              href: 'https://youtu.be/yNU3TM6PKCk',
              variant: 'primary',
              size: 'large',
              className: 'h-11 w-auto md:h-12',
              attributes: { 'aria-label': `Подключить тариф ${plan.title}`, target: '_blank', rel: 'noopener noreferrer' }
            }) %>
          </div>
        </article>
      <% }) %>
    </div>

    <p class="mx-auto max-w-[760px] text-center text-[14px] leading-[1.48] text-text lg:text-[16px]">
      Доступно бесплатное тестирование на демо-счёте для безопасного знакомства с ботом
    </p>
  </div>
</section>
