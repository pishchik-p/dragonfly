<section id="income" class="pb-[calc(var(--layout-section-gap)/2)] pt-0" aria-labelledby="revenue-stats-title" data-section="revenue-stats">
  <div class="layout-container">
    <article class="flex w-full flex-col items-center gap-8 overflow-hidden rounded-[16px] bg-background p-4 text-white md:gap-11 md:rounded-[24px] md:p-11">
      <h2 id="revenue-stats-title" class="type-h2 w-full text-white">Сколько денег я&nbsp;получу?</h2>

      <dl class="flex w-full flex-col gap-8 md:flex-row md:gap-6">
        <div class="flex min-w-0 flex-1 flex-col items-start gap-2 md:gap-6">
          <dt class="w-full text-[20px] font-semibold leading-[1.16] text-white lg:text-[28px]">
            Средняя месячная <br>доходность&nbsp;составляет:
          </dt>
          <dd class="flex items-baseline gap-2 whitespace-nowrap md:gap-4">
            <span class="text-[20px] font-semibold leading-[1.16] text-white lg:text-[28px]">от</span>
            <strong class="text-[64px] font-bold leading-none text-accent lg:text-[96px]">10%</strong>
            <span class="text-[20px] font-semibold leading-[1.16] text-white lg:text-[28px]">в&nbsp;месяц</span>
          </dd>
        </div>

        <div class="flex min-w-0 flex-1 flex-col items-start gap-2 md:gap-6">
          <dt class="w-full text-[20px] font-semibold leading-[1.16] text-white lg:text-[28px]">
            Средняя годовая<br>доходность&nbsp;составляет:
          </dt>
          <dd class="flex flex-col items-start">
            <span class="flex items-baseline gap-2 whitespace-nowrap md:gap-4">
              <span class="text-[20px] font-semibold leading-[1.16] text-white lg:text-[28px]">от</span>
              <strong class="text-[64px] font-bold leading-none text-accent lg:text-[96px]">214%</strong>
              <span class="text-[20px] font-semibold leading-[1.16] text-white lg:text-[28px]">годовых&nbsp;*</span>
            </span>
            <span class="type-body-small text-text">* с&nbsp;учётом капитализации (сложного процента)</span>
          </dd>
        </div>
      </dl>

      <div class="flex w-full justify-center">
        <%- include('../ui/button', {
          label: 'Подключить бота',
          href: 'https://youtu.be/xOcFb_trRMw?si=qsBxsej-1dmHWzk9',
          variant: 'primary',
          size: 'large',
          className: 'w-full md:w-auto',
          attributes: { target: '_blank', rel: 'noopener noreferrer' }
        }) %>
      </div>
    </article>
  </div>
</section>
