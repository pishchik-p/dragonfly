<%
  const iconName = typeof name === 'string' ? name : 'checkmark';
  const iconSize = typeof size === 'string' || typeof size === 'number' ? String(size) : '24';
  const iconClassName = typeof className === 'string' ? className : '';
  const hasIconLabel = typeof label === 'string' && label.length > 0;
  const iconLabel = hasIconLabel ? label : iconName;
  const isDecorativeIcon = typeof decorative === 'boolean' ? decorative : !hasIconLabel;
  const iconTitleId = `icon-title-${iconName.replace(/[^a-z0-9_-]/gi, '-')}`;
  const a11yAttrs = isDecorativeIcon
    ? 'aria-hidden="true" focusable="false"'
    : `role="img" aria-labelledby="${iconTitleId}"`;
%>

<svg
  class="inline-block shrink-0 align-middle text-current <%= iconClassName %>"
  width="<%= iconSize %>"
  height="<%= iconSize %>"
  viewBox="0 0 24 24"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  data-icon="<%= iconName %>"
  <%- a11yAttrs %>
>
  <% if (!isDecorativeIcon) { %><title id="<%= iconTitleId %>"><%= iconLabel %></title><% } %>

  <% if (iconName === 'telegram') { %>
    <path d="M21 4.5 3.75 11.28c-.86.34-.83 1.58.05 1.87l4.38 1.46 1.68 5.06c.27.8 1.28 1.05 1.89.47l2.47-2.36 4.47 3.25c.73.54 1.78.13 1.95-.76L23 5.82c.17-.9-.86-1.66-2-.132Z" fill="currentColor"/>
    <path d="m8.35 14.38 9.45-5.84-6.76 7.23-.24 3.27-1.54-4.4-.91-.26Z" fill="currentColor" opacity="0.35"/>
  <% } else if (iconName === 'youtube') { %>
    <path d="M21.58 7.18a2.56 2.56 0 0 0-1.8-1.8C18.2 4.95 12 4.95 12 4.95s-6.2 0-7.78.43a2.56 2.56 0 0 0-1.8 1.8A26.7 26.7 0 0 0 2 12a26.7 26.7 0 0 0 .42 4.82 2.56 2.56 0 0 0 1.8 1.8c1.58.43 7.78.43 7.78.43s6.2 0 7.78-.43a2.56 2.56 0 0 0 1.8-1.8A26.7 26.7 0 0 0 22 12a26.7 26.7 0 0 0-.42-4.82Z" fill="currentColor"/>
    <path d="m10 15.05 5.2-3.05L10 8.95v6.1Z" fill="var(--color-background, #1F1E1B)"/>
  <% } else if (iconName === 'mail') { %>
    <path d="M4 6.5h16a1.5 1.5 0 0 1 1.5 1.5v8a1.5 1.5 0 0 1-1.5 1.5H4A1.5 1.5 0 0 1 2.5 16V8A1.5 1.5 0 0 1 4 6.5Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
    <path d="m3.25 7.25 8.75 6 8.75-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
  <% } else if (iconName === 'checkmark') { %>
    <circle cx="12" cy="12" r="10" fill="currentColor" opacity="0.16"/>
    <path d="m7.5 12.25 3 3 6-6.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
  <% } else if (iconName === 'plus') { %>
    <circle cx="12" cy="12" r="10" fill="currentColor" opacity="0.16"/>
    <path d="M12 7v10M7 12h10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
  <% } else if (iconName === 'menu') { %>
    <path d="M4 6.5h16M4 12h16M4 17.5h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
  <% } else if (iconName === 'arrow-right') { %>
    <path d="M4 12h15M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
  <% } else if (iconName === 'arrow-left') { %>
    <path d="M20 12H5M11 6l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
  <% } else if (iconName === 'chevron-down') { %>
    <path d="m6 9 6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
  <% } else if (iconName === 'play') { %>
    <circle cx="12" cy="12" r="10" fill="currentColor" opacity="0.16"/>
    <path d="M10 8.75v6.5c0 .77.84 1.25 1.5.85l5.1-3.25a1 1 0 0 0 0-1.7L11.5 7.9c-.66-.4-1.5.08-1.5.85Z" fill="currentColor"/>
  <% } else { %>
    <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2"/>
  <% } %>
</svg>
